# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it's already in .gitignore

# Your Anthropic API key (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# The URL of your frontend (your Netlify URL)
# Use * during development, lock it down for production
ALLOWED_ORIGIN=https://your-app.netlify.app

# Port the server runs on (Render sets this automatically)
PORT=3000
